import java.util.ArrayList;
import java.util.Scanner;

class Ticket {
    String name, email, issue, status;

    Ticket(String name, String email, String issue) {
        this.name = name;
        this.email = email;
        this.issue = issue;
        this.status = "OPEN";
    }

    void display() {
        System.out.println("----------------------------");
        System.out.println("Name   : " + name);
        System.out.println("Email  : " + email);
        System.out.println("Issue  : " + issue);
        System.out.println("Status : " + status);
    }
}

public class Main {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);
        ArrayList<Ticket> tickets = new ArrayList<>();

        int choice;

        do {
            System.out.println("\n===== HELP DESK MENU =====");
            System.out.println("1. Submit Ticket");
            System.out.println("2. View Tickets");
            System.out.println("3. Exit");

            System.out.print("Enter choice: ");
            choice = sc.nextInt();
            sc.nextLine();

            switch (choice) {

                case 1:
                    System.out.print("Enter Name: ");
                    String name = sc.nextLine();

                    System.out.print("Enter Email: ");
                    String email = sc.nextLine();

                    System.out.print("Enter Issue: ");
                    String issue = sc.nextLine();

                    tickets.add(new Ticket(name, email, issue));
                    System.out.println("Ticket submitted successfully!");
                    break;

                case 2:
                    if (tickets.isEmpty()) {
                        System.out.println("No tickets found.");
                    } else {
                        for (Ticket t : tickets) {
                            t.display();
                        }
                    }
                    break;

                case 3:
                    System.out.println("Exiting system...");
                    break;

                default:
                    System.out.println("Invalid choice!");
            }

        } while (choice != 3);

        sc.close();
    }
}
