<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Online Help Desk Support System</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #fff9e6; /* Soft yellow background */
            margin: 0;
            padding: 0;
        }

        header {
            background-color: #c0392b; /* Red header */
            color: white;
            padding: 20px;
            text-align: center;
        }

        nav {
            background-color: #e74c3c; /* Red nav */
            padding: 12px;
            text-align: center;
        }

        nav a {
            color: white;
            text-decoration: none;
            margin: 15px;
            font-weight: bold;
        }

        nav a:hover {
            color: #ffdede; /* lighter hover effect */
        }

        section {
            padding: 20px;
            margin: 20px;
            background-color: #ffffff;
            border-radius: 8px;
            box-shadow: 0px 3px 8px rgba(0,0,0,0.1);
        }

        input, select, textarea {
            width: 100%;
            padding: 8px;
            margin-top: 5px;
            margin-bottom: 15px;
            border-radius: 5px;
            border: 1px solid #ccc;
        }

        input[type="radio"] {
            width: auto;
        }

        input[type="submit"], input[type="reset"] {
            background-color: #c0392b; /* Red buttons */
            color: white;
            border: none;
            cursor: pointer;
            width: 48%;
            padding: 10px;
        }

        input[type="submit"]:hover,
        input[type="reset"]:hover {
            background-color: #e74c3c; /* Lighter red hover */
        }

        footer {
            background-color: #c0392b; /* Red footer */
            color: white;
            text-align: center;
            padding: 12px;
        }
    </style>

</head>
<body>

    <header>
        <h1>Online Help Desk Support System</h1>
        <p>Your Problem, Our Priority</p>
    </header>

    <nav>
        <a href="#home">Home</a>
        <a href="#ticket">Submit Ticket</a>
        <a href="#status">Check Status</a>
        <a href="#contact">Contact</a>
    </nav>

    <section id="home">
        <h2>Welcome</h2>
        <p>This system allows users to submit issues and check ticket status easily.</p>
    </section>

    <section id="ticket">
        <h2>Submit Support Ticket</h2>
        <form>
            <label>Full Name:</label>
            <input type="text" required>

            <label>Email:</label>
            <input type="email" required>

            <label>Department:</label>
            <select>
                <option>Technical Support</option>
                <option>Billing Department</option>
                <option>Account Management</option>
                <option>Customer Service</option>
            </select>

            <label>Priority Level:</label><br>
            <input type="radio" name="priority"> Low
            <input type="radio" name="priority"> Medium
            <input type="radio" name="priority"> High
            <br><br>

            <label>Describe Your Issue:</label>
            <textarea rows="4"></textarea>

            <input type="submit" value="Submit Ticket">
            <input type="reset" value="Clear">
        </form>
    </section>

    <section id="status">
        <h2>Check Ticket Status</h2>
        <form>
            <label>Enter Ticket ID:</label>
            <input type="text">
            <input type="submit" value="Check Status">
        </form>
    </section>

    <section id="contact">
        <h2>Contact Information</h2>
        <p>Email: support@helpdesk.com</p>
        <p>Phone: +1 800 123 4567</p>
        <p>Working Hours: Monday - Friday (9 AM - 6 PM)</p>
    </section>

    <footer>
        <p>&copy; 2026 Online Help Desk Support System | All Rights Reserved</p>
    </footer>

</body>
</html>
